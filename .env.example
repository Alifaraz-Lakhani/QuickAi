# ==================== APPLICATION ====================
# Frontend Configuration
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_clerk_publishable_key_here

# Backend Configuration
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ==================== DATABASE ====================
# PostgreSQL Configuration
POSTGRES_USER=quickai
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=quickai_db
DATABASE_URL=postgresql://quickai:your_secure_password_here@postgres:5432/quickai_db

# ==================== AUTHENTICATION ====================
# Clerk Authentication
CLERK_SECRET_KEY=sk_live_your_clerk_secret_key_here

# ==================== AI & GENERATION ====================
# OpenAI Configuration
OPENAI_API_KEY=sk-your_openai_api_key_here

# ==================== IMAGE PROCESSING ====================
# Cloudinary Configuration (for image handling)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ==================== DEVOPS TOOLS ====================
# Docker Registry Configuration
REGISTRY_URL=docker.io
REGISTRY_USERNAME=your_registry_username
REGISTRY_PASSWORD=your_registry_password

# ==================== MONITORING ====================
# Prometheus Configuration
PROMETHEUS_RETENTION=30d
PROMETHEUS_SCRAPE_INTERVAL=15s

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123
GRAFANA_URL=http://grafana:3000

# Loki Configuration
LOKI_RETENTION_DAYS=30

# ==================== JENKINS ====================
# Jenkins Configuration
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=your_jenkins_password_here

# ==================== SONARQUBE ====================
# SonarQube Configuration
SONAR_HOST_URL=http://sonarqube:9000
SONAR_LOGIN=your_sonarqube_token_here
SONAR_PASSWORD=your_sonarqube_password_here

# ==================== KUBERNETES ====================
# Kubernetes Configuration (if deploying to K8s)
K8S_NAMESPACE=quickai
K8S_REPLICAS=2
K8S_IMAGE_PULL_POLICY=Always

# ==================== ANSIBLE ====================
# Ansible Configuration
ANSIBLE_USER=ubuntu
ANSIBLE_SSH_KEY=/path/to/your/ssh/key
ANSIBLE_INVENTORY_PATH=ansible/inventory.ini

# ==================== SECURITY ====================
# Secrets Management
SECRET_MANAGEMENT_SYSTEM=vault  # or k8s-secrets, env, etc.
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=your_vault_token_here

# ==================== LOGGING ====================
# Application Logging
LOG_FORMAT=json
LOG_OUTPUT=console,file
LOG_FILE_PATH=/var/log/quickai/app.log

# ==================== EMAIL NOTIFICATIONS ====================
# SMTP Configuration for alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_EMAIL=admin@quickai.com

# ==================== SLACK INTEGRATION ====================
# Slack Webhook for notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==================== FEATURE FLAGS ====================
ENABLE_MONITORING=true
ENABLE_ALERTS=true
ENABLE_LOGS_AGGREGATION=true
ENABLE_KUBERNETES_DEPLOYMENT=false

# ==================== DEBUG ====================
DEBUG=false
VERBOSE_LOGGING=false
